profile default {
	output eDP-1 enable scale 1
}

profile office {
	output eDP-1 disable
	output "LG Electronics LG HDR 4K 0x000A97CC" mode 3840x2160 position 0,0 scale 1
}

profile homeoffice {
	output eDP-1 disable
    output HDMI-A-1 mode 3840x2160  position 1920,0 scale 1.25
	output "LG Electronics LG ULTRAFINE 110NTRLH4414" mode 3840x2160  position 4479,0 scale 1.0
}
