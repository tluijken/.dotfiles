markup=1
actions=1

default-timeout=5000
max-visible=5
sort=-time

font=JetBrainsMono Nerd Font 12
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#313244
border-size=2
border-radius=8
padding=12

format=<b>%s</b>\n%b

icon-path=/run/current-system/sw/share/icons/hicolor

[hidden]
format=(%h more)

[urgency=low]
border-color=#a6e3a1

[urgency=low actionable]
border-color=#a6e3a1

[urgency=normal]
border-color=#89b4fa

[urgency=normal actionable]
border-color=#89b4fa

[urgency=high]
border-color=#f38ba8
background-color=#313244

[urgency=high actionable]
border-color=#f38ba8
